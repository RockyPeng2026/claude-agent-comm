{
  "description": "agent-comm child signal hooks — fires child_signal.js on lifecycle events for event-driven parent-child communication",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/child_signal.js\" --state permission",
            "timeout": 2
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/child_signal.js\" --state notification",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/child_signal.js\" --state stop",
            "timeout": 2
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/child_signal.js\" --state stop_failure",
            "timeout": 2
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "agent-comm-deliveries.jsonl",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/rewake_delivery.js\"",
            "asyncRewake": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
