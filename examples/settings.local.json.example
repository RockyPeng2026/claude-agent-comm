{
  "_comment": "目标项目 .claude/settings.local.json 需要的段（合并到已有 settings）。permissions.allow 豁免框架文件编辑（否则每改一次 .claude/comm/ 或 .claude/hooks/ 都要人工批）",
  "permissions": {
    "allow": [
      "Edit(.claude/comm/**)",
      "Edit(.claude/hooks/**)",
      "Read(.claude/signals/**)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/child_signal.js\" --state permission",
            "timeout": 2
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/child_signal.js\" --state notification",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/child_signal.js\" --state stop",
            "timeout": 2
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/child_signal.js\" --state stop_failure",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
